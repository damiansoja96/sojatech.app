---
const { title, description, tech, url } = Astro.props;
---

<article class="project-card">
  <h3><a href={url} target="_blank" rel="noopener">{title}</a></h3>
  <p>{description}</p>
  <div class="tech">
    {tech.map((t: string) => <span class="tag">{t}</span>)}
  </div>
</article>

<style>
  .project-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .tech {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .tag {
    background: rgba(88, 166, 255, 0.1);
    color: var(--accent);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }
</style>
